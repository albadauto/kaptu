@page "/"

@page "/login"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height:100vh;">
    <MudPaper Elevation="10" Class="pa-8" Rounded="Rounded.Large" Style="width:100%;">
        <MudStack Spacing="3">
            <MudGrid Justify="Justify.Center">
                <MudItem>
                    <MudImage Src="logo.png" Width="200" />
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.body2" Align="Align.Center">
                Faça login para continuar
            </MudText>

            <MudDivider />

            <MudTextField Label="Email"
                          Variant="Variant.Outlined"
                          StartIcon="Icons.Material.Filled.Email"
                          Required="true"
                          @bind-Value="Email" />

            <MudTextField Label="Senha"
                          Variant="Variant.Outlined"
                          StartIcon="Icons.Material.Filled.Lock"
                          InputType="InputType.Password"
                          Required="true"
                          @bind-Value="Password" />

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudLink Href="/forgot-password">Esqueceu a senha?</MudLink>
            </MudStack>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       FullWidth="true"
                       OnClick="OnLogin">
                Entrar
            </MudButton>

            <MudDivider />

            <MudText Typo="Typo.body2" Align="Align.Center">
                Não é assinante?
                <MudLink Href="/bepremium">Virar Premium</MudLink>
            </MudText>

        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private string Email { get; set; }
    private string Password { get; set; }
    private bool RememberMe;

    private async Task OnLogin()
    {
        // TODO: integrar autenticação
        await Task.Delay(500);
    }
}

