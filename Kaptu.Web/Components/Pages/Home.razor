@page "/"
@rendermode InteractiveServer
@inject IAuthService AuthService
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height:100vh;">
    <MudPaper Elevation="10" Class="pa-8" Rounded="Rounded.Large" Style="width:100%;">
        <MudStack Spacing="3">
            <MudGrid Justify="Justify.Center">
                <MudItem>
                    <MudImage Src="logo.png" Width="200" />
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.body2" Align="Align.Center">
                Faça login para continuar
            </MudText>

            <MudDivider />
            <MudForm @ref="form">
                <MudTextField Label="Email"
                              Variant="Variant.Outlined"
                              StartIcon="Icons.Material.Filled.Email"
                              Required="true"
                              @bind-Value="dto.Email" />

                <MudTextField Label="Senha"
                              Variant="Variant.Outlined"
                              StartIcon="Icons.Material.Filled.Lock"
                              InputType="InputType.Password"
                              Required="true"
                              @bind-Value="dto.Password" />

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudLink Href="/forgotpassword">Esqueceu a senha?</MudLink>
                </MudStack>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           OnClick="OnLogin">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                    }
                    else
                    {
                        <MudText>Salvar</MudText>
                    }
                </MudButton>
            </MudForm>
            <MudDivider />

            <MudText Typo="Typo.body2" Align="Align.Center">
                Não é assinante?
                <MudLink Href="/bepremium">Virar Premium</MudLink>
            </MudText>

        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private LoginDTO dto { get; set; } = new();
    private MudForm form;
    private bool RememberMe;
    private bool _isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.Logout();
            StateHasChanged(); 

        }
    }

    private async Task OnLogin()
    {
        _isLoading = true;
        if (form.IsValid)
        {
            var result = await AuthService.Authenticate(dto);
            if (result)
            {
                Snackbar.Add("Login realizado com sucesso!", Severity.Success);
                navigationManager.NavigateTo("/dashboard");
            }
            else
            {
                Snackbar.Add("Falha no login. Verifique suas credenciais.", Severity.Error);
            }
        }
        _isLoading = false;
    }
}

