@page "/changepassword"
<div class="gradient-bg">
    <MudContainer MaxWidth="MaxWidth.False"
                  Class="d-flex align-center justify-center"
                  Style="min-height:100vh;">

        <MudPaper Elevation="10"
                  Class="pa-10"
                  Style="border-radius:24px; max-width:800px; width:100%;">
            <MudText Typo="Typo.h5" Align="Align.Center">
                Esqueci minha senha
            </MudText>
            <MudGrid Class="mt-2">
                <MudItem xs="12">
                    <MudTextField T="string" Label="Código enviado no e-mail" Placeholder="000000" Variant="Variant.Filled" />
                </MudItem>

                <MudItem xs="12" Class="mt-1">
                    <MudTextField T="string" Label="Nova senha" Placeholder="*******" InputType="InputType.Password" Variant="Variant.Filled" />
                </MudItem>
            </MudGrid>

            <MudGrid Justify="Justify.Center" Class="mt-2">
                <MudItem>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" >Atualizar Senha</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
</div>

